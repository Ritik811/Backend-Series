<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Mini Chat</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/registerOrLogin.css" />
  </head>
  <body>
    <div class="auth-container-box">
      <div class="auth-card">
        <div class="auth-header-title">
          <h2>Create Account 🚀</h2>
          <p>Join Mini Chat to start conversations with friends</p>
        </div>

        <!-- 📄 Register Form -->
        <form action="/chats/register" method="POST" class="auth-form">
          <div class="form-input-group">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Choose a unique username (e.g., ritik)"
              required
              autocomplete="off"
            />
          </div>

          <div class="form-input-group">
            <label for="email">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="Enter your email (e.g., ritik@gmail.com)"
              required
              autocomplete="off"
            />
          </div>

          <div class="form-input-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Create a strong password (min 6 chars)"
              required
            />
          </div>

          <button type="submit" class="btn-auth-submit">Register Now</button>
        </form>

        <div class="auth-card-footer">
          <p>
            Already have an account? <a href="/chats/login">Login here 🔑</a>
          </p>
          <a href="/chats" class="back-to-dashboard">⬅️ Back to Dashboard</a>
        </div>
      </div>
    </div>
  </body>
</html>
