<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Mini Chat</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/registerOrLogin.css" />
  </head>
  <body>
    <div class="auth-container-box">
      <div class="auth-card">
        <div class="auth-header-title">
          <h2>Welcome Back! 🔑</h2>
          <p>Login to your Mini Chat account to continue</p>
        </div>

        <form action="/chats/login" method="POST" class="auth-form">
          <div class="form-input-group">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              placeholder="Enter your username (e.g., ritik)"
              required
              autocomplete="off"
            />
          </div>

          <div class="form-input-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              placeholder="Enter your secret password"
              required
            />
          </div>

          <button type="submit" class="btn-auth-submit">Sign In</button>
        </form>

        <div class="auth-card-footer">
          <p>
            Don't have an account?
            <a href="/chats/register">Register here 🚀</a>
          </p>
          <a href="/chats" class="back-to-dashboard">⬅️ Back to Dashboard</a>
        </div>
      </div>
    </div>
  </body>
</html>
