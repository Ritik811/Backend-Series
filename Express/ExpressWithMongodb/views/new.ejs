<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Send New Message</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="form-wrapper">
      <div class="form-header">
        <h2>Start New Chat</h2>
        <p>Send a message to your friend instantly</p>
      </div>

      <form action="/chats" method="POST" class="chat-form">
        <div class="form-group">
          <label for="from">From (Your Name):</label>
          <input
            type="text"
            id="from"
            name="from"
            placeholder="e.g. ritik"
            required
          />
        </div>

        <div class="form-group">
          <label for="to">To (Receiver Name):</label>
          <input
            type="text"
            id="to"
            name="to"
            placeholder="e.g. vishal"
            required
          />
        </div>

        <div class="form-group">
          <label for="msg">Message:</label>
          <textarea
            id="msg"
            name="msg"
            rows="4"
            placeholder="Type your message here..."
            maxLength="50"
            required
          ></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-send">Send Message 🚀</button>
          <a href="/chats" class="btn-back">Cancel</a>
        </div>
      </form>
    </div>
  </body>
</html>
